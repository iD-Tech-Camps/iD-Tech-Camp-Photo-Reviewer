# Copy to .env.test.local and fill in the values shown by `npx supabase start`.
# .env.test.local is gitignored. The API test suite (npm run test:api) reads
# from this file FIRST, then falls back to .env.local — keeping production
# credentials out of the test harness.

# Local Supabase (from `npx supabase status`):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Any string is fine here; the test harness uses it to verify the cron
# routes' Bearer-token check. Default is "test-cron-secret" if unset.
CRON_SECRET=test-cron-secret
